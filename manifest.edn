{"pipelines"
 [{"steps"
   [{"args" {"command" "stats"}, "fn" "agent.invoke", "id" "stats"}
    {"args"
     {"message"
      "You are ISCO Workforce Coordinator. Based on the following new data, write a concise social post (1-2 sentences, informative and specific). Data: $stats.text"},
     "depends_on" ["stats"],
     "fn" "agent.chat",
     "id" "compose"}
    {"args" {"template" "$compose.text"},
     "depends_on" ["compose"],
     "fn" "derive:social",
     "id" "announce"}],
   "trigger" {"cron" "0 0 * * 1", "type" "cron"}}
  {"steps"
   [{"args"
     {"command" "summarize", "params" {"code" "$input.record.code"}},
     "fn" "agent.invoke",
     "id" "summarize"}],
   "trigger"
   {"collections" ["com.etzhayyim.apps.isco.occupation"],
    "type" "subscribeRepos"}}
  {"steps"
   [{"args"
     {"sql"
      "MATCH (o:Occupation) RETURN count(o) AS registered LIMIT 1"},
     "fn" "graph.query",
     "id" "registrationCheck"}],
   "trigger" {"nsid" "com.etzhayyim.apps.isco.health", "type" "xrpc"}}
  {"steps"
   [{"args"
     {"sql"
      "MATCH (n) WHERE n.repo = $did RETURN count(n) AS nodeCount, coalesce(max(n._seq), 0) AS latestSeq LIMIT 1"},
     "fn" "graph.query",
     "id" "coverageNodes"}
    {"args"
     {"sql"
      "MATCH (n) WHERE n.repo = $did AND n.collection IS NOT NULL RETURN n.collection AS collection, count(n) AS cnt ORDER BY cnt DESC LIMIT 10"},
     "depends_on" [],
     "fn" "graph.query",
     "id" "coverageCollections"}
    {"args"
     {"params"
      {"actorName" "isco",
       "bucket" "6h",
       "collection" "com.etzhayyim.apps.isco.coverageSnapshot",
       "latestSeq" 0,
       "nanoid" "wfc8k3n1",
       "nodeCount" "$coverageNodes.rows[0].nodeCount"},
      "template"
      "MERGE (c:ActorCoverageSnapshot {actorDid: $did, bucket: $bucket, actorName: $actorName, nanoid: $nanoid, nodeCount: $nodeCount, latestTs: $latestTs, repo: $did, collection: $collection, status: 'active'})"},
     "depends_on" ["coverageNodes"],
     "fn" "graph.write",
     "id" "coverageSnapshot"}
    {"args"
     {"message"
      "You are ISCO Workforce Coordinator. Based on the following new data, write a concise social post (1-2 sentences, informative and specific). Data: $coverageSnapshot.text"},
     "depends_on" ["coverageSnapshot"],
     "fn" "agent.chat",
     "id" "compose"}
    {"args" {"template" "$compose.text"},
     "depends_on" ["compose"],
     "fn" "derive:social",
     "id" "announce"}],
   "trigger" {"cron" "0 */6 * * *", "type" "cron"}}
  {"steps"
   [{"args"
     {"sql"
      "MATCH (c:ActorCoverageSnapshot {actorDid: $did}) RETURN c.nodeCount AS nodeCount, c.latestSeq AS latestSeq, c.topCollections AS topCollections, c._seq AS snapshotSeq LIMIT 1"},
     "fn" "graph.query",
     "id" "coverageStats"}
    {"args"
     {"sql"
      "MATCH (c:ActorCoverageSnapshot {actorDid: $did}) RETURN c.nodeCount AS totalNodes LIMIT 1"},
     "depends_on" [],
     "fn" "graph.query",
     "id" "coverageHealth"}],
   "trigger"
   {"nsid" "com.etzhayyim.apps.isco.coverage.get", "type" "xrpc"}}],
 "capabilities"
 ["graph.query"
  "graph.write"
  "agent.chat"
  "agent.invoke"
  "derive:social"],
 "@context" "https://etzhayyim.com/ns/actor/v1",
 "@id" "did:web:isco.etzhayyim.com",
 "heartbeatRequired" true,
 "displayName" "ISCO Workforce Coordinator",
 "runtime" "k8s-langserver",
 "profile"
 {"agentType" "autonomous",
  "capabilities"
  ["list"
   "get"
   "search"
   "tree"
   "create"
   "stats"
   "describe"
   "summarize"],
  "description"
  "ILO ISCO-08 full classification with 619 Multi-DIDs. Occupation search, tree traversal, workforce mobility/compensation/skills analysis.",
  "displayName" "ISCO Workforce Coordinator",
  "isBot" true,
  "operator" "etzhayyim.co.jp"},
 "standardRule" "per-did-kyumei-shinka-autonomy@2026-04-13",
 "performerType" "service",
 "legacyExecutionTier" "T1",
 "edge" "sveltekit-proxy",
 "nanoid" "wfc8k3n1",
 "name" "isco",
 "complianceDocs"
 ["90-docs/rules/compliance/per-did-kyumei-shinka-autonomy.md"
  "90-docs/platform/260403-live-data-kyumei-shinka-consolidated.md"],
 "requiredLoops" ["shinka" "koji" "kyumei" "domain-knowledge"],
 "domainKnowledgeRequired" true,
 "uiType" "yoro",
 "triggers"
 {"subscribeRepos"
  {"collections"
   ["com.etzhayyim.apps.isco.occupation"
    "com.etzhayyim.apps.isco.workforceMobility"]}},
 "convoSystemPrompt"
 "You are the ISCO workforce coordinator agent. You manage the complete ILO ISCO-08 occupational classification with 619 path-based DIDs (did:web:isco.etzhayyim.com:occupation:{code}). You support 4-level hierarchy (major/submajor/minor/unit), workforce mobility analysis, compensation tracking, and skills gap analysis. On first heartbeat you register all 619 DIDs. Use Murakumo LLM for occupation group summaries.",
 "standardStatus" "required",
 "requiredCollections"
 ["com.etzhayyim.apps.standard.shinkaEvolution"
  "com.etzhayyim.apps.standard.shinkaKnowledge"],
 "description"
 "ILO ISCO-08 full classification managed as 1 app x 619 Multi-DIDs. 4-level hierarchy (major/submajor/minor/unit). Workforce mobility, compensation, and skills gap analysis via dedicated WIT interfaces.",
 "governance" {"classification" "internal", "raci" "responsible"}}
